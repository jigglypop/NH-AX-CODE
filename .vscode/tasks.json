{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "group": "build",
      "problemMatcher": "$tsc",
      "label": "npm: compile"
    },
    {
      "type": "npm",
      "script": "compile:extension",
      "group": "build",
      "problemMatcher": "$tsc",
      "label": "npm: compile:extension"
    },
    {
      "type": "npm",
      "script": "dev:webview",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:"
        }
      },
      "label": "npm: dev:webview"
    },
    {
      "label": "dev:react-hmr",
      "dependsOrder": "sequence",
      "dependsOn": [
        "npm: compile:extension",
        "npm: dev:webview"
      ],
      "problemMatcher": []
    }
  ]
}
