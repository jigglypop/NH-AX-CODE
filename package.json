{
  "name": "clarus-code",
  "displayName": "NH-AX-CODE",
  "description": "VS Code용 사내 코드 에이전트.",
  "version": "0.1.0",
  "publisher": "clarus",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*",
    "onStartupFinished",
    "onView:clarusCode.chat",
    "onCommand:clarusCode.openChat",
    "onCommand:clarusCode.openPanel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "clarusCode",
          "title": "NH-AX-CODE",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "clarusCode": [
        {
          "type": "webview",
          "id": "clarusCode.chat",
          "name": "채팅"
        }
      ]
    },
    "commands": [
      {
        "command": "clarusCode.openChat",
        "title": "NH-AX-CODE: 채팅 열기"
      },
      {
        "command": "clarusCode.openPanel",
        "title": "NH-AX-CODE: 패널 열기"
      },
      {
        "command": "clarusCode.restoreLastCheckpoint",
        "title": "NH-AX-CODE: 최근 체크포인트 복원"
      },
      {
        "command": "clarusCode.listCheckpoints",
        "title": "NH-AX-CODE: 체크포인트 목록"
      },
      {
        "command": "clarusCode.showCommandHistory",
        "title": "NH-AX-CODE: 명령 실행 히스토리"
      },
      {
        "command": "clarusCode.probeEndpoints",
        "title": "NH-AX-CODE: 엔드포인트 진단"
      },
      {
        "command": "clarusCode.editPermissionRules",
        "title": "NH-AX-CODE: 권한 규칙 편집"
      },
      {
        "command": "clarusCode.gitCommit",
        "title": "NH-AX-CODE: AI 커밋 메시지로 커밋"
      },
      {
        "command": "clarusCode.reloadMcpServers",
        "title": "NH-AX-CODE: MCP 서버 재시작"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "clarusCode.openChat"
        },
        {
          "command": "clarusCode.openPanel"
        },
        {
          "command": "clarusCode.restoreLastCheckpoint"
        },
        {
          "command": "clarusCode.listCheckpoints"
        },
        {
          "command": "clarusCode.showCommandHistory"
        },
        {
          "command": "clarusCode.probeEndpoints"
        },
        {
          "command": "clarusCode.editPermissionRules"
        },
        {
          "command": "clarusCode.gitCommit"
        },
        {
          "command": "clarusCode.reloadMcpServers"
        }
      ]
    },
    "configuration": {
      "title": "NH-AX-CODE",
      "properties": {
        "clarusCode.provider": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic",
            "openai-compatible"
          ],
          "default": "openai",
          "description": "사용할 모델 제공자입니다."
        },
        "clarusCode.apiKey": {
          "type": "string",
          "default": "",
          "description": "선택한 제공자의 API 키입니다."
        },
        "clarusCode.model": {
          "type": "string",
          "default": "gpt-5.5",
          "description": "기본 모델 이름입니다."
        },
        "clarusCode.openAICompatibleBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434/v1",
          "description": "OpenAI 호환 API 기본 URL입니다."
        },
        "clarusCode.requestHeaders": {
          "type": "object",
          "default": {},
          "description": "사내 게이트웨이에 추가로 보낼 HTTP 헤더입니다."
        },
        "clarusCode.endpointMode": {
          "type": "string",
          "enum": [
            "auto",
            "chat-completions",
            "completions",
            "responses"
          ],
          "default": "auto",
          "description": "엔드포인트 모드입니다. 자동은 채팅, 응답, 완성 순서로 시도합니다."
        },
        "clarusCode.streamResponses": {
          "type": "boolean",
          "default": true,
          "description": "서버가 지원하면 실시간 스트리밍 응답을 사용합니다."
        },
        "clarusCode.autoApplyFileActions": {
          "type": "boolean",
          "default": true,
          "description": "생성된 파일 작업을 확인 없이 적용합니다."
        },
        "clarusCode.commandAllowlist": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "허용할 명령 접두사 목록입니다. 비어 있으면 모든 명령을 허용합니다(denylist 제외)."
        },
        "clarusCode.commandDenylist": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["rm -rf", "rmdir /s", "format", "del /f", "git push --force"],
          "description": "차단할 명령 접두사 목록입니다. allowlist보다 우선합니다."
        },
        "clarusCode.runCommandsInTerminal": {
          "type": "boolean",
          "default": false,
          "description": "명령을 출력 캡처 대신 통합 터미널에서 실행합니다."
        },
        "clarusCode.verifyCommand": {
          "type": "string",
          "default": "",
          "description": "파일 수정 후 자동으로 실행할 검증 명령입니다 (예: npm test). 결과는 에이전트 자기비평에 들어갑니다."
        },
        "clarusCode.toolMode": {
          "type": "string",
          "enum": ["actions-block", "native"],
          "default": "actions-block",
          "description": "도구 호출 방식입니다. native는 provider의 function-calling을 사용합니다 (chat-completions/Anthropic 전용, 스트리밍 비활성)."
        },
        "clarusCode.autoCompactThreshold": {
          "type": "number",
          "default": 120000,
          "minimum": 0,
          "description": "대화 컨텍스트가 이 문자 수를 넘으면 오래된 메시지를 자동 요약합니다. 0이면 비활성."
        },
        "clarusCode.hooks": {
          "type": "object",
          "default": {},
          "description": "훅 명령입니다. { \"preAction\": \"cmd\", \"postAction\": \"cmd\", \"onError\": \"cmd\" }. preAction이 0이 아닌 코드로 끝나면 작업이 차단됩니다."
        },
        "clarusCode.mcpServers": {
          "type": "object",
          "default": {},
          "description": "MCP stdio 서버입니다. { \"이름\": { \"command\": \"npx\", \"args\": [\"-y\", \"@modelcontextprotocol/server-filesystem\", \".\"] } }"
        },
        "clarusCode.maxWorkspaceFiles": {
          "type": "number",
          "default": 80,
          "minimum": 10,
          "maximum": 500,
          "description": "컨텍스트에 포함할 워크스페이스 파일 경로의 최대 개수입니다."
        }
      }
    }
  },
  "scripts": {
    "compile": "npm run compile:webview && npm run compile:extension",
    "compile:extension": "tsc -p ./",
    "compile:webview": "vite build --config webview/vite.config.ts",
    "dev:webview": "vite --config webview/vite.config.ts --host 127.0.0.1",
    "watch": "tsc -watch -p ./",
    "watch:extension": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.92.0",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "^2.0.1",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-query": "^5.101.2",
    "date-fns": "^4.4.0",
    "jotai": "^2.20.1",
    "pdfjs-dist": "^6.1.200",
    "react-datepicker": "^9.1.0",
    "read-excel-file": "^9.2.0",
    "streamdown": "^2.5.0",
    "tailwindcss": "^4.3.2"
  }
}
